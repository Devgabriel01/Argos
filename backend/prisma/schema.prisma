generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ANALYST")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agency {
  id        String     @id @default(uuid())
  name      String
  cnpj      String     @unique
  state     String
  contracts Contract[]
  createdAt DateTime   @default(now())
}

model Supplier {
  id             String     @id @default(uuid())
  name           String
  cnpj           String     @unique
  foundedAt      DateTime
  totalContracts Int        @default(0)
  contracts      Contract[]
  createdAt      DateTime   @default(now())
}

model Contract {
  id              String             @id @default(uuid())
  number          String             @unique
  object          String
  value           Float
  startDate       DateTime
  endDate         DateTime
  competitorCount Int                @default(1)
  riskScore       Int                @default(0)
  riskLevel       String             @default("LOW")
  riskFactors     String             @default("[]")
  source          String             @default("MANUAL")
  agencyId        String
  supplierId      String
  agency          Agency             @relation(fields: [agencyId], references: [id])
  supplier        Supplier           @relation(fields: [supplierId], references: [id])
  additives       ContractAdditive[]
  history         ContractHistory[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model ContractAdditive {
  id          String   @id @default(uuid())
  contractId  String
  description String
  valueAdded  Float
  addedAt     DateTime @default(now())
  contract    Contract @relation(fields: [contractId], references: [id])
}

model ContractHistory {
  id            String   @id @default(uuid())
  contractId    String
  contract      Contract @relation(fields: [contractId], references: [id])
  previousScore Int
  newScore      Int
  previousLevel String
  newLevel      String
  changedBy     String
  reason        String
  createdAt     DateTime @default(now())
}
